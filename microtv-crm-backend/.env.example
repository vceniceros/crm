APP_NAME=MicroTV CRM Backend
ENVIRONMENT=development
HOST=0.0.0.0
PORT=8010

# Database
DATABASE_URL=postgresql+psycopg://crmmicrotv:crmmicrotv@localhost:5433/crm_microtv

# CORS
CORS_ORIGINS=http://localhost:4200,http://localhost:5173
CORS_ORIGIN_REGEX=^https?://(localhost|127\.0\.0\.1|192\.168\.\d{1,3}\.\d{1,3}|10\.\d{1,3}\.\d{1,3}\.\d{1,3}|172\.(1[6-9]|2\d|3[0-1])\.\d{1,3}\.\d{1,3})(:\d+)?$

# Auth interno (completar en cada entorno)
AUTH_BASE_URL=http://localhost:8001
AUTH_LOGIN_PATH=/v1/auth/login
AUTH_TIMEOUT_SECONDS=10
AUTH_MANAGEMENT_EMAIL=admin@ycc.local
AUTH_MANAGEMENT_PASSWORD=changeme-secure-password
AUTH_JWT_SECRET=change-me
AUTH_JWT_ALGORITHM=HS256
AUTH_JWT_ISSUER=auth.crm.ycc.internal
AUTH_JWT_AUDIENCE=microtv-platform
AUTH_SERVICE_RECAPTCHA_TOKEN=crm-backend

# Web Push (VAPID) - completar para habilitar push notifications
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_CLAIMS_SUB=mailto:valentinocolella@microtv.com.ar

# Multimedia
CRM_MEDIA_ROOT=public
CRM_MEDIA_PUBLIC_URL=/media

# Limites de upload (bytes)
PRODUCT_IMAGES_MAX_BYTES=2097152
TASK_IMAGES_MAX_BYTES=8388608
TASK_VIDEOS_MAX_BYTES=134217728
SATISFACTION_IMAGES_MAX_BYTES=8388608
SATISFACTION_VIDEOS_MAX_BYTES=67108864
SATISFACTION_FORM_EXPIRY_HOURS=72

# Bootstrap de roles y defaults
AUTO_PROVISION_CRM_ROLE=true
DEFAULT_ADMIN_AUTH_ROLES=admin,platform_admin,company_admin
DEFAULT_DEPOSITO_AUTH_ROLES=operador_deposito,company_operator
DEFAULT_TECH_AUTH_ROLES=tecnico_campo
DEPOSITO_DEMO_TENANT_ID=YCC
