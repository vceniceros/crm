# ══════════════════════════════════════════════════════════════════════════════
# AUTH.MICROTV.AR — Environment variables
# Copy to .env and fill in values for each environment.
# Variables marked [PROD] must be set in production. Never commit .env.
# ══════════════════════════════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+psycopg://authmicrotv:changeme@localhost:5433/auth_microtv

# ── JWT ───────────────────────────────────────────────────────────────────────
# [PROD] Strong random secret, shared with all microservices that verify tokens
JWT_SECRET=dev-secret-local
JWT_ALGORITHM=HS256
JWT_ISSUER=auth.crm.ycc.internal
JWT_AUDIENCE=microtv-platform
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_MINUTES=10080
LOGIN_TICKET_EXPIRE_MINUTES=10

# ── Service-to-service auth ───────────────────────────────────────────────────
# [PROD] Shared secret for internal callbacks (e.g. pay.microtv.ar → auth).
# Must match SERVICE_JWT_SECRET in pay.microtv.ar.
SERVICE_JWT_SECRET=change-me-service

# ── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:5173,https://saas.microtv.ar,https://admin.microtv.ar

# ── SMTP (transactional email) ────────────────────────────────────────────────
SMTP_HOST=smtp.microtv.ar
SMTP_PORT=587
SMTP_USER=noreply@microtv.ar
SMTP_PASSWORD=
SMTP_FROM=noreply@microtv.ar
SMTP_FROM_NAME=MicroTV

# ── Frontend URLs (used in email links) ──────────────────────────────────────
# URL base de saas (verificación de email, reset de contraseña)
FRONTEND_URL=https://saas.microtv.ar
# URL base de saas para links de invitación a compañías
SAAS_BASE_URL=https://saas.microtv.ar

# ── Google reCAPTCHA v3 ───────────────────────────────────────────────────────
# Obtener en: https://www.google.com/recaptcha/admin/create (tipo: reCAPTCHA v3)
RECAPTCHA_SECRET_KEY=
RECAPTCHA_MIN_SCORE=0.5

# ── AFIP (validación fiscal, padrón A4) ───────────────────────────────────────
# API pública, no requiere credenciales. Solo cambiar si AFIP modifica la URL.
AFIP_BASE_URL=https://soa.afip.gob.ar/sr-padron/v2

# ── Application ───────────────────────────────────────────────────────────────
ENVIRONMENT=development

# ── CRM Internal Bootstrap (idempotent) ──────────────────────────────────────
CRM_AUTH_TENANT_TYPE=company
CRM_AUTH_TENANT_ID=YCC
CRM_AUTH_ADMIN_EMAIL=admin@ycc.local
CRM_AUTH_ADMIN_PASSWORD=changeme-secure-password
CRM_AUTH_ADMIN_NAME=Administrador CRM
