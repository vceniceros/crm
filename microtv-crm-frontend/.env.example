CRM_API_BASE_URL=http://192.168.10.50:8010
CRM_MEDIA_PUBLIC_URL=/media
DEV_MODE=true

IMAGE_MAX_WIDTH=1280
IMAGE_MAX_HEIGHT=1280
IMAGE_QUALITY=0.75
IMAGE_TARGET_FORMAT=webp
VIDEO_MAX_SIZE_MB=50

# Optional when DEV_MODE=true:
