# API y media
CRM_API_BASE_URL=http://localhost:8010
CRM_MEDIA_PUBLIC_URL=/media

# Web Push (clave publica VAPID)
VAPID_PUBLIC_KEY=

# Runtime de SSR (produccion)
SERVER_NAME=crm.ycc.group
PORT=8201
NODE_ENV=production

# Desarrollo
DEV_MODE=true

# Cuentas seed por defecto cuando DEV_MODE=true:
# admin@ycc.local / changeme-secure-password -> admin
# operador.crm@yccbrothers.com / Passw0rd! -> deposito
# deposito.aux@yccbrothers.com / Passw0rd! -> deposito
# ejecutivo.crm@yccbrothers.com / Passw0rd! -> ejecutivo
# tecnico.campo@yccbrothers.com / Passw0rd! -> tecnico

# Mapa base
NEXT_PUBLIC_MAP_STYLE_URL=https://crm.ycc.group/map-tiles/argentina/styles/basic-preview/style.json
NEXT_PUBLIC_MAP_DEFAULT_LAT=-34.6037
NEXT_PUBLIC_MAP_DEFAULT_LON=-58.3816
NEXT_PUBLIC_MAP_DEFAULT_ZOOM=12

# Compresion y limites de multimedia en frontend
IMAGE_CAPTURE_MAX_WIDTH=1280
IMAGE_CAPTURE_MAX_HEIGHT=720
IMAGE_CAPTURE_QUALITY=0.82
IMAGE_MAX_UPLOAD_MB=10
IMAGE_TARGET_FORMAT=webp
VIDEO_MAX_SIZE_MB=50

# Optional when DEV_MODE=true:
# DEV_LOGIN_ACCOUNTS_JSON=[{"label":"Admin","email":"admin@example.com","password":"Passw0rd!","roleLabel":"admin"}]

# Google Maps
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
GOOGLE_MAPS_MAP_ID=DEMO_MAP_ID
GOOGLE_MAPS_LANGUAGE=es-AR
GOOGLE_MAPS_REGION=AR
GOOGLE_MAPS_VERSION=weekly
GOOGLE_MAPS_AUTH_REFERRER_POLICY=origin
